# D League Clubhouse Environment Configuration
# Copy to .env and fill real values for production

NODE_ENV=production
PORT=4174

# Data storage (use persistent volume in production)
DATA_DIR=./data

# Demo mode: true for local testing / demo deployments. false for real production.
DEMO_MODE=true

# Sync configuration
ENABLE_SCHEDULED_SYNC=false
SYNC_INTERVAL_MS=300000

# Security
REQUEST_BODY_LIMIT_BYTES=1048576
EXPORT_TOKEN=your-long-random-export-token-here-at-least-32-chars
SYNC_TOKEN=your-long-random-sync-token-here-at-least-32-chars

# Paystack (REQUIRED for real payments)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_CALLBACK_URL=https://yourdomain.com

# Integrations - FPL uses public APIs (no key)
# Live projection enhancement (optional). Use {teamId} and {round} placeholders
LIVE_FPL_API_TEMPLATE=

# UCL Fantasy adapter template. Replace with real UEFA or third-party template when confirmed.
# Example: https://api.uclfantasy.example.com/entries/{teamId}/matchdays/{round}
UCL_FANTASY_API_TEMPLATE=

# Optional: For live projection or UCL mock endpoints in testing

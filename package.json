{
  "name": "d-league-clubhouse",
  "version": "1.0.0",
  "description": "D League Clubhouse — Premium manager-centric fantasy football community app for FPL, UCL Fantasy, H2H, cups, fines, and transparent payouts.",
  "private": true,
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "check": "node --check server.js",
    "build:css": "tailwindcss -i ./public/input.css -o ./public/tailwind.css --minify",
    "build": "npm run build:css",
    "seed": "node -e \"require('./server.js').seedDemoIfNeeded && console.log('Seeded')\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
